{
  "name": "macropad",
  "version": "1.0.0",
  "description": "Configurable phone-to-PC macro pad",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.server.json && electron-vite dev",
    "build": "tsc -p tsconfig.server.json && electron-vite build",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:all": "npm run build && electron-builder --linux --mac --win",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "tsc -p tsconfig.server.json && vitest run --workspace vitest.workspace.ts",
    "test:watch": "tsc -p tsconfig.server.json && vitest --workspace vitest.workspace.ts"
  },
  "build": {
    "appId": "com.chunkies.macropad",
    "productName": "MacroPad",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "pwa",
        "to": "pwa"
      }
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    }
  },
  "dependencies": {
    "adm-zip":    "^0.5.17",
    "express":    "^4.19.2",
    "multer":     "^2.1.1",
    "qrcode":     "^1.5.4",
    "selfsigned": "^2.4.1",
    "ws":         "^8.17.0"
  },
  "devDependencies": {
    "@types/express":     "^4.17.21",
    "@types/multer":      "^1.4.11",
    "@types/node":        "^20.0.0",
    "@types/ws":          "^8.5.10",
    "electron":           "^30.0.0",
    "electron-builder":   "^24.13.3",
    "electron-vite":      "^2.3.0",
    "typescript":         "^5.4.0",
    "vite":               "^5.2.0",
    "vitest":             "^2.0.0"
  }
}
