{
  "name": "macropad",
  "version": "1.0.0",
  "description": "Configurable phone-to-PC macro pad",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest tests/ --forceExit",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --mac --win"
  },
  "build": {
    "appId": "com.chunkies.macropad",
    "productName": "MacroPad",
    "directories": {
      "output": "../dist"
    },
    "extraResources": [
      {
        "from": "../pwa",
        "to": "pwa"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "selfsigned": "^2.4.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^30.3.0"
  }
}
