{
  "id": "text-macro",
  "name": "Text Macro",
  "version": "1.0.0",
  "description": "Type a block of text, pause, then fire a hotkey — all from one button press. Great for snippets, form fills, and keyboard shortcuts.",
  "author": "MacroPad Team",
  "authorUrl": "https://github.com/chunkies/macropad",
  "homepage": "https://github.com/chunkies/macropad/tree/master/plugins/text-macro",
  "price": 0,
  "license": "MIT",
  "tags": ["productivity", "keyboard", "macro"],
  "minAppVersion": "1.0.0",
  "actions": [
    {
      "key": "text-macro.run",
      "label": "Type text + hotkey",
      "componentType": "button",
      "params": [
        {
          "key": "text",
          "label": "Text to type",
          "type": "textarea",
          "placeholder": "Hello, world!"
        },
        {
          "key": "delay",
          "label": "Pause before hotkey (ms)",
          "type": "number",
          "default": 1000,
          "placeholder": "1000"
        },
        {
          "key": "hotkey",
          "label": "Hotkey after pause (e.g. ctrl+Return)",
          "type": "text",
          "placeholder": "ctrl+Return"
        }
      ]
    },
    {
      "key": "text-macro.type-only",
      "label": "Type text only",
      "componentType": "button",
      "params": [
        {
          "key": "text",
          "label": "Text to type",
          "type": "textarea",
          "placeholder": "Hello, world!"
        }
      ]
    },
    {
      "key": "text-macro.hotkey-only",
      "label": "Fire hotkey only",
      "componentType": "button",
      "params": [
        {
          "key": "hotkey",
          "label": "Hotkey (e.g. ctrl+shift+t)",
          "type": "text",
          "placeholder": "ctrl+shift+t"
        }
      ]
    }
  ]
}
